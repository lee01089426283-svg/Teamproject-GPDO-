# 모든 텍스트 파일의 줄바꿈을 LF로 통일 (OS 무관)
* text=auto eol=lf

# Python
*.py text eol=lf

# 설정 파일
*.cfg   text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.ini   text eol=lf

# 바이너리 파일은 변환하지 않음
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.zip   binary
*.pkl   binary